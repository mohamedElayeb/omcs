# ╔══════════════════════════════════════════════════════════╗
# ║          OMCS Production Environment Variables          ║
# ║     Copy this file to .env and fill in the values       ║
# ╚══════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=omcs
POSTGRES_USER=omcs_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Backend ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
NODE_ENV=production
DB_SYNC=true  # Set to 'true' ONLY for first deploy to create tables, then change to 'false'

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://admin.omcs.com.ly,https://shop.omcs.com.ly

# ── Public URLs (used during frontend build) ─────────────
# These get baked into the Next.js client bundles at build time.
BACKEND_PUBLIC_URL=https://api.omcs.com.ly

# ── Domain Names (for Nginx) ─────────────────────────────
ADMIN_DOMAIN=admin.omcs.com.ly
STOREFRONT_DOMAIN=shop.omcs.com.ly
API_DOMAIN=api.omcs.com.ly
