# ╔══════════════════════════════════════════════════════════╗
# ║          OMCS Production Environment Variables          ║
# ║     Copy this file to .env and fill in the values       ║
# ╚══════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=omcs
POSTGRES_USER=omcs_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Backend ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
NODE_ENV=production
DB_SYNC=true  # Set to 'true' ONLY for first deploy to create tables, then change to 'false'

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Example: https://admin.outletmaster.ly,https://shop.outletmaster.ly
CORS_ORIGINS=*

# ── Public URLs (used during frontend build) ─────────────
# These get baked into the Next.js client bundles at build time.
# Set this to the URL where your BACKEND is publicly accessible.
# If using a domain:        https://api.outletmaster.ly
# If using IP:              http://YOUR_SERVER_IP:4000
# If using Cloudflare Tunnel: https://your-tunnel-name.trycloudflare.com
BACKEND_PUBLIC_URL=http://YOUR_SERVER_IP:4000

# ── Domain Names (for Nginx - optional) ──────────────────
ADMIN_DOMAIN=admin.outletmaster.ly
STOREFRONT_DOMAIN=shop.outletmaster.ly
API_DOMAIN=api.outletmaster.ly
