# ─── Database (use your hosting provider's PostgreSQL URL) ───
DATABASE_URL=postgresql://user:password@host:5432/omcs

# ─── JWT ───
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ─── App ───
PORT=4000
NODE_ENV=production

# ─── CORS (comma-separated allowed origins) ───
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-storefront.vercel.app

# ─── Database sync (set true on first deploy to create tables, then remove) ───
DB_SYNC=true

# ─── Optional: Enable Swagger in production ───
# ENABLE_SWAGGER=true
